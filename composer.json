{
    "name": "codecheck/ojs-plugin",
    "description": "CODECHECK Plugin for OJS",
    "type": "ojs-plugin",
    "require": {
        "php": ">=8.0",
        "knplabs/github-api": "^3.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "http-interop/http-factory-guzzle": "^1.0",
        "vlucas/phpdotenv": "^5.6",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "APP\\plugins\\generic\\codecheck\\": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "APP\\plugins\\generic\\codecheck\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html tests/coverage/html",
        "test:filter": "phpunit --filter",
        "phpcs": "phpcs --standard=PSR12 classes/",
        "phpstan": "phpstan analyse classes/ --level=5",
        "lint": "composer phpcs && composer phpstan",
        "fix": "phpcbf --standard=PSR12 classes/"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    }
}